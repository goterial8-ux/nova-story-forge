# GOOGLE_GENAI_USE_VERTEXAI: Tells @google/genai to route through Vertex AI rather than Gemini Developer API.
GOOGLE_GENAI_USE_VERTEXAI=True

# GOOGLE_CLOUD_PROJECT: The active Google Cloud Project ID used to bill and authenticate Vertex AI API calls.
GOOGLE_CLOUD_PROJECT=your-google-cloud-project

# GOOGLE_CLOUD_LOCATION: The Google Cloud and Vertex AI region location to resolve prediction requests (defaults to 'global').
GOOGLE_CLOUD_LOCATION=global

# PORT: The port that the Express + Vite server listens to for server-side responses.
PORT=8080

# Anthropic Claude Integration Settings
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=your-claude-model

# Claude-compatible TKBK Writer Settings
# Store the real value only in Cloud Run Secret Manager, then mount it as env var TKBK_API_KEY.
TKBK_API_KEY=
TKBK_CLAUDE_ENDPOINT=https://api.tkbk.io/claude/v1/messages
CLAUDE_WRITER_PROVIDER=tkbk
CLAUDE_WRITER_MODEL=claude-sonnet-4-6
CLAUDE_WRITER_MAX_TOKENS=8000

# Script Writer provider flag: tkbk, anthropic, or claude. Gemini is disabled for Script Writer.
SCRIPT_WRITER_PROVIDER=tkbk
