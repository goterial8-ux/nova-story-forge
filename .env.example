# Cloud Run / local server
PORT=8080

# Vertex AI for planning stages: raw_idea, story_dna, story_plan, scene_cards, supervisor
GOOGLE_GENAI_USE_VERTEXAI=True
GOOGLE_CLOUD_PROJECT=your-google-cloud-project
GOOGLE_CLOUD_LOCATION=global

# Script Writer provider.
# Use claude_compatible for AiPrimeTech or any Anthropic-compatible gateway.
# Supported values: claude_compatible, aiprimetech, tkbk, anthropic, or claude.
# Gemini is intentionally disabled for the script_writer stage in server.ts.
CLAUDE_WRITER_PROVIDER=claude_compatible
SCRIPT_WRITER_PROVIDER=claude_compatible

# Universal Anthropic/Claude-compatible gateway settings.
# AiPrimeTech example:
CLAUDE_COMPAT_BASE_URL=https://aiprimetech.io/v1
CLAUDE_COMPAT_MESSAGES_ENDPOINT=https://aiprimetech.io/v1/messages
CLAUDE_COMPAT_API_KEY=

# Model and output budget for Script Writer.
# Change to a model that your gateway account supports.
CLAUDE_WRITER_MODEL=claude-sonnet-4-6
CLAUDE_WRITER_MAX_TOKENS=8000

# Backward-compatible TKBK settings.
# You can use these instead of CLAUDE_COMPAT_* if you want to switch back to TKBK.
TKBK_BASE_URL=https://api.tkbk.io
TKBK_CLAUDE_ENDPOINT=https://api.tkbk.io/claude/v1/messages
TKBK_API_KEY=

# Direct Anthropic fallback only.
# Leave empty when using AiPrimeTech/TKBK.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=8000

# Server-side prompt compaction limit before Claude-compatible calls.
ANTHROPIC_MAX_INPUT_CHARS=24000
